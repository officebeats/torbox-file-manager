{
  "manifest_version": 3,
  "name": "File Manager for TorBox (Unofficial)",
  "version": "0.1.2",
  "description": "An elegant, unofficial extension with folders, tags, and streaming quick-actions to organize your TorBox downloads.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open File Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "index.html",
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.torbox.app/*",
    "https://torbox.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://torbox.app/*"],
      "js": ["src/content.js"],
      "run_at": "document_end"
    }
  ]
}
